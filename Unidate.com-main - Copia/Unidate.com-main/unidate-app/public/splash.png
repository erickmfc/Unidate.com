<svg xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024">
  <defs>
    <linearGradient id="splashGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#8B5CF6" />
      <stop offset="100%" stop-color="#EC4899" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur in="SourceAlpha" stdDeviation="20" />
      <feOffset dx="0" dy="10" result="offsetblur" />
      <feComponentTransfer>
        <feFuncA type="linear" slope="0.3" />
      </feComponentTransfer>
      <feMerge>
        <feMergeNode />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="1024" height="1024" fill="#f9fafb" />
  
  <!-- Logo Container -->
  <g transform="translate(512, 512)" filter="url(#shadow)">
    <!-- Graduation Cap -->
    <rect x="-120" y="-120" width="240" height="60" rx="10" fill="url(#splashGradient)" />
    <rect x="-20" y="-60" width="40" height="80" fill="url(#splashGradient)" />
    <rect x="-140" y="20" width="280" height="20" rx="10" fill="url(#splashGradient)" />
    
    <!-- Heart Shape -->
    <path d="M-70,60 C-70,10 -20,10 0,40 C20,10 70,10 70,60 C70,110 0,150 0,150 C0,150 -70,110 -70,60 Z" fill="url(#splashGradient)" />
  </g>
  
  <!-- Text -->
  <g transform="translate(512, 700)">
    <text x="0" y="0" font-family="'Inter', sans-serif" font-size="80" font-weight="700" text-anchor="middle" fill="#6366f1">UniDate</text>
    <text x="0" y="50" font-family="'Inter', sans-serif" font-size="24" text-anchor="middle" fill="#4b5563">Sua faculdade. Suas conexões.</text>
  </g>
</svg>